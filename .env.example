# ============================================
# .env.example - Template v3
# ============================================
# Copia pra /opt/AGENTE/.env (Linux) ou ~/AGENTE/.env (Mac)
# Substitui placeholders {{...}} pelos valores reais
# chmod 600 .env (NUNCA committar com secrets reais)
# ============================================

# ----- AGENTE BASICO (obrigatorio) -----
AGENTE_NAME=nadia_cli
OWNER_NAME=User
TMUX_SESSION=nadia_cli
TMUX_USER=root

# ----- TELEGRAM (obrigatorio) -----
TELEGRAM_BOT_TOKEN={{TELEGRAM_BOT_TOKEN}}
ALLOWED_USERS={{TELEGRAM_USER_IDS_COMMA_SEPARATED}}
DEBOUNCE_SECONDS=8

# ----- POSTGRESQL (gerado pelo SETUP) -----
DATABASE_URL=postgres://nadia_cli:{{PG_PASSWORD}}@127.0.0.1:5432/nadia_cli_memory

# ----- AUDIO BIDIRECIONAL (opcional) -----
OPENAI_API_KEY={{OPENAI_KEY_OR_BLANK}}
ELEVENLABS_API_KEY={{ELEVENLABS_KEY_OR_BLANK}}
ELEVENLABS_VOICE_ID={{ELEVENLABS_VOICE_ID}}

# ----- CLAUDE API (opcional, se usar API direta alem de Pro/Max) -----
ANTHROPIC_API_KEY={{OPCIONAL_SE_USAR_API_DIRETA}}

# ----- DEPLOY PUBLICO (opcional) -----
GITHUB_TOKEN={{GITHUB_PAT_PARA_DEPLOY}}
VERCEL_TOKEN={{VERCEL_TOKEN}}
VERCEL_TEAM_ID={{VERCEL_TEAM_ID}}
CLOUDFLARE_API_TOKEN={{CLOUDFLARE_DNS_TOKEN}}
CLOUDFLARE_ZONE_ID={{CLOUDFLARE_ZONE_ID}}

# ----- AGENT-MANAGER (PM2) -----
AGENT_MANAGER_PORT=3600
AGENT_MANAGER_DOMAIN=nadia_cli.{{DOMAIN}}

# ----- CLONE SDR (opcional) -----
SDR_OFFER_NAME={{NOME_DA_OFERTA}}
SDR_PITCH={{PITCH_CURTO}}
SDR_PRICE={{PRECO}}
SDR_CHECKOUT_URL={{LINK_CHECKOUT}}
SDR_DAILY_LIMIT=50
SDR_HOURS=09-22

# ----- HEALTHCHECK -----
HEALTHCHECK_INTERVAL=120
HEALTHCHECK_ALERT_THROTTLE=300

# ----- DAILY REPORT -----
DAILY_REPORT_HOUR=9
DAILY_REPORT_TIMEZONE=America/Sao_Paulo
