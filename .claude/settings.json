{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Bash|Grep|Glob|NotebookEdit|WebFetch|WebSearch|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/AGENTE/.claude/hooks/enforce_delegation.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Agent",
      "Task",
      "TodoWrite",
      "Bash(echo *> /opt/AGENTE-bot/outbox/*)",
      "Bash(cat *> /opt/AGENTE-bot/outbox/*)"
    ],
    "deny": []
  }
}
